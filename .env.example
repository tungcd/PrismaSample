# Database
DATABASE_URL="postgresql://admin:secure_password@localhost:5432/smart_canteen?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth.js - CMS
NEXTAUTH_URL_CMS="http://localhost:3000"
NEXTAUTH_SECRET_CMS="your-nextauth-secret-cms-change-this-in-production"

# NextAuth.js - Client
NEXTAUTH_URL_CLIENT="http://localhost:3001"
NEXTAUTH_SECRET_CLIENT="your-nextauth-secret-client-change-this-in-production"

# NestJS API
JWT_SECRET="your-jwt-secret-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# SMS Provider (Optional - for OTP)
SMS_PROVIDER="esms" # or "twilio"
SMS_API_KEY="your-sms-api-key"
SMS_API_SECRET="your-sms-api-secret"

# Email Service
EMAIL_PROVIDER="nodemailer" # or "sendgrid"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-email-password"
EMAIL_FROM="Smart Canteen <noreply@smartcanteen.com>"

# Cloud Storage (Optional)
CLOUD_STORAGE_PROVIDER="local" # or "s3", "cloudinary"
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_REGION="ap-southeast-1"
# AWS_S3_BUCKET="smart-canteen"

# Sentry (Optional)
# SENTRY_DSN="your-sentry-dsn"

# Application
NODE_ENV="development"
APP_NAME="Smart Canteen"
APP_URL="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX="100"
