{
  "name": "smart-canteen",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter=@smart-canteen/prisma prisma generate",
    "db:push": "pnpm --filter=@smart-canteen/prisma prisma db push",
    "db:migrate": "pnpm --filter=@smart-canteen/prisma prisma migrate dev",
    "db:studio": "pnpm --filter=@smart-canteen/prisma prisma studio",
    "db:seed": "pnpm --filter=@smart-canteen/prisma tsx prisma/seed.ts",
    "db:reset": "pnpm --filter=@smart-canteen/prisma prisma migrate reset"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "turbo": "^1.11.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
